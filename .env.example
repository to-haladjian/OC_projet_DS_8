# Supabase PostgreSQL connection string (session pooler, port 5432)
# Get yours via Supabase dashboard -> Connect button (top of page) -> Session pooler
# See docs/supabase_setup.md for the full walkthrough.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# HuggingFace token (used by .github/workflows/deploy.yml to push to HF Spaces)
HF_TOKEN=hf_xxxxx
